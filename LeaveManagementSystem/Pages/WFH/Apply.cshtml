@page
@model LeaveManagementSystem.Pages.WFH.ApplyModel

@{
    ViewData["Title"] = "Apply WFH";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="page-title mb-1">Apply WFH</h2>
        <p class="page-subtitle mb-0">Submit a work from home request</p>
    </div>

    <a asp-page="List" class="btn btn-secondary action-btn">
        Back
    </a>
</div>

<div class="card lms-card">
    <div class="card-body">

        <form method="post" enctype="multipart/form-data">

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label class="form-label">Employee</label>

                    @if (Model.IsAdmin)
                    {
                        <select asp-for="EmployeeId" class="form-select">
                            <option value="">Select Employee</option>

                            @foreach (var employee in Model.EmployeeList)
                            {
                                <option value="@employee.Id">@employee.Name</option>
                            }
                        </select>
                    }
                    else
                    {
                        <input type="hidden" asp-for="EmployeeId" />
                        <input class="form-control" value="@(Model.CurrentUserName ?? Model.EmployeeList.FirstOrDefault(e => e.Id == Model.EmployeeId)?.Name)" disabled />
                    }

                    <span asp-validation-for="EmployeeId" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Start Date</label>
                    <input asp-for="StartDate" type="date" class="form-control" />
                    <span asp-validation-for="StartDate" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">End Date</label>
                    <input asp-for="EndDate" type="date" class="form-control" />
                    <span asp-validation-for="EndDate" class="text-danger"></span>
                </div>

                <div class="col-md-12 mb-3">
                    <label class="form-label">Reason</label>
                    <textarea asp-for="Reason" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Reason" class="text-danger"></span>
                </div>

                <div class="col-md-12 mb-3">
                    <label class="form-label">Supporting Document</label>
                    <input asp-for="SupportingDocument" type="file" class="form-control" />
                </div>

            </div>

            <button type="submit" class="btn btn-success action-btn">
                Apply WFH
            </button>

        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}