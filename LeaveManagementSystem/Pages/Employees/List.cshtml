@page
@using LeaveManagementSystem.AppCode
@model LeaveManagementSystem.Pages.Employees.ListModel

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="page-title mb-1">Employee List</h2>
        <p class="page-subtitle mb-0">
            Manage all employees
        </p>
    </div>

    <a asp-page="Add" class="btn btn-primary action-btn">
        + Add Employee
    </a>
</div>

<div class="card lms-card">
    <div class="card-body">

        <table class="table table-hover lms-table">

            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Department</th>
                    <th>Designation</th>
                    <th>Status</th>
                    <th>Created On</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model.EmployeeList)
                {
                    <tr>

                        <td class="fw-semibold">
                            @item.Name
                        </td>

                        <td>
                            @item.Email
                        </td>

                        <td>
                            @item.DepartmentName
                        </td>

                        <td>
                            @item.DesignationName
                        </td>

                        <td>

                            @if (item.Status == "Active")
                            {
                                <span class="badge bg-success">
                                    Active
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    Inactive
                                </span>
                            }

                        </td>

                        <td>
                            @Html.DisplayDate(item.CreatedOnUTC)
                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>
</div>