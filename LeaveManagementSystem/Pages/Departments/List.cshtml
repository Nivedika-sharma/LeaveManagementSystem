@page
@using LeaveManagementSystem.AppCode
@model LeaveManagementSystem.Pages.Departments.ListModel

@{
    ViewData["Title"] = "Department List";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="page-title mb-1">Department List</h2>
        <p class="page-subtitle mb-0">Manage all company departments</p>
    </div>

    <a asp-page="Add" class="btn btn-primary action-btn">
        + Add Department
    </a>
</div>

<div class="card lms-card">
    <div class="card-body">
        <table class="table table-hover lms-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Created By</th>
                    <th>Created On</th>
                    <th>Updated By</th>
                    <th>Updated On</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var department in Model.DepartmentList)
                {
                    <tr>
                        <td class="fw-semibold">@department.Name</td>
                        <td>@department.Description</td>
                        <td>@department.CreatedBy</td>
                        <td>@Html.DisplayDate(department.CreatedOnUTC)</td>
                        <td>@department.UpdatedBy</td>
                        <td>@Html.DisplayDate(department.UpdatedOnUTC)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>