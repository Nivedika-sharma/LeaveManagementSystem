@page
@using LeaveManagementSystem.AppCode
@model LeaveManagementSystem.Pages.Designations.ListModel

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h2 class="page-title mb-1">Designation List</h2>

        <p class="page-subtitle mb-0">
            Manage employee designations
        </p>
    </div>

    <a asp-page="Add" class="btn btn-primary action-btn">
        + Add Designation
    </a>

</div>

<div class="card lms-card">

    <div class="card-body">

        <table class="table table-hover lms-table">

            <thead>
                <tr>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Created On</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model.DesignationList)
                {
                    <tr>

                        <td class="fw-semibold">
                            @item.Name
                        </td>

                        <td>
                            @item.Description
                        </td>

                        <td>
                            @Html.DisplayDate(item.CreatedOnUTC)
                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>