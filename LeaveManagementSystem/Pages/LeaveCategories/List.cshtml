@page
@using LeaveManagementSystem.AppCode
@model LeaveManagementSystem.Pages.LeaveCategories.ListModel

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h2 class="page-title mb-1">Leave Categories</h2>

        <p class="page-subtitle mb-0">
            Manage all leave categories
        </p>
    </div>

    <a asp-page="Add" class="btn btn-primary action-btn">
        + Add Leave Category
    </a>

</div>

<div class="card lms-card">

    <div class="card-body">

        <table class="table table-hover lms-table">

            <thead>
                <tr>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Document Required</th>
                    <th>Created On</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model.LeaveCategoryList)
                {
                    <tr>

                        <td class="fw-semibold">
                            @item.Title
                        </td>

                        <td>
                            @item.Description
                        </td>

                        <td>

                            @if (item.IsDocumentRequired)
                            {
                                <span class="badge bg-danger">
                                    Required
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success">
                                    Optional
                                </span>
                            }

                        </td>

                        <td>
                            @Html.DisplayDate(item.CreatedOnUTC)
                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>